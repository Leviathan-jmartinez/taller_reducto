                                                                                                                                                                            },
                                                                                                                                                                "name":  "Registrar compra",
                                                                                                                                                                "defaultDiagram":  true,
                                                                                                                                                                "ownedViews":  [
                                                                                                                                                                                   {
                                                                                                                                                                                       "_type":  "UMLNoteView",
                                                                                                                                                                                       "_id":  "ID000000000515",
                                                                                                                                                                                       "_parent":  {
                                                                                                                                                                                                       "$ref":  "ID000000000514"
                                                                                                                                                                                                   },
                                                                                                                                                                                       "font":  "Arial;13;0",
                                                                                                                                                                                       "parentStyle":  false,
                                                                                                                                                                                       "left":  50,
                                                                                                                                                                                       "top":  50,
                                                                                                                                                                                       "width":  900,
                                                                                                                                                                                       "height":  620,
                                                                                                                                                                                       "text":  "Convencion: Actor -\u003e Vista -\u003e Conexion -\u003e Entidades/Tablas\n\nParticipantes:\n- Actor\n- Vista\n- Conexion\n- orden_compra\n- orden_compra_detalle\n- compra_cabecera\n- compra_detalle\n- stock\n- movimientostock\n- cuentas_a_pagar\n- libro_compra\n\nMensajes:\n1. Actor -\u003e Vista: selecciona orden de compra\n2. Vista -\u003e Conexion: consulta OC activa\n3. Conexion -\u003e orden_compra: consulta cabecera\n4. Conexion -\u003e orden_compra_detalle: consulta detalle\n5. Conexion -\u003e Vista: retorna OC y detalle\n6. Actor -\u003e Vista: carga factura, timbrado, condicion y cuotas\n7. Vista -\u003e Vista: valida detalle, factura no duplicada y totales\n8. Actor -\u003e Vista: confirma registro\n9. Vista -\u003e Conexion: llama conexion\n10. Conexion -\u003e compra_cabecera: inserta compra\n11. Conexion -\u003e compra_detalle: inserta detalle\n12. Conexion -\u003e stock: actualiza stock\n13. Conexion -\u003e movimientostock: registra recepcion\n14. Conexion -\u003e cuentas_a_pagar: genera cuotas\n15. Conexion -\u003e libro_compra: registra libro\n16. Conexion -\u003e orden_compra: actualiza estado\n17. Conexion -\u003e Vista: retorna compra registrada"
                                                                                                                                                                                   }
                                                                                                                                                                               ]
                                                                                                                                                            }
                                                                                                                                                        ]
                                                                                                                                  }
                                                                                                                              ]
