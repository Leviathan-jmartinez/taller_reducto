                                                                                                                                                                "name":  "Generar orden de compra",
                                                                                                                                                                "defaultDiagram":  true,
                                                                                                                                                                "ownedViews":  [
                                                                                                                                                                                   {
                                                                                                                                                                                       "_type":  "UMLNoteView",
                                                                                                                                                                                       "_id":  "ID000000000483",
                                                                                                                                                                                       "_parent":  {
                                                                                                                                                                                                       "$ref":  "ID000000000482"
                                                                                                                                                                                                   },
                                                                                                                                                                                       "font":  "Arial;13;0",
                                                                                                                                                                                       "parentStyle":  false,
                                                                                                                                                                                       "left":  50,
                                                                                                                                                                                       "top":  50,
                                                                                                                                                                                       "width":  900,
                                                                                                                                                                                       "height":  620,
                                                                                                                                                                                       "text":  "Convencion: Actor -\u003e Vista -\u003e Conexion -\u003e Entidades/Tablas\n\nParticipantes:\n- Actor\n- Vista\n- Conexion\n- presupuesto_compra\n- presupuesto_detalle\n- orden_compra\n- orden_compra_detalle\n- articulo_proveedor\n\nMensajes:\n1. Actor -\u003e Vista: selecciona presupuesto\n2. Vista -\u003e Conexion: consulta presupuesto activo\n3. Conexion -\u003e presupuesto_compra: consulta cabecera\n4. Conexion -\u003e presupuesto_detalle: consulta detalle\n5. Conexion -\u003e Vista: retorna presupuesto\n6. Actor -\u003e Vista: define fecha de entrega\n7. Vista -\u003e Vista: valida datos cargados\n8. Actor -\u003e Vista: confirma generacion\n9. Vista -\u003e Conexion: llama conexion\n10. Conexion -\u003e orden_compra: inserta orden\n11. Conexion -\u003e orden_compra_detalle: inserta detalle\n12. Conexion -\u003e articulo_proveedor: registra precio proveedor\n13. Conexion -\u003e presupuesto_compra: actualiza estado procesado\n14. Conexion -\u003e Vista: retorna OC generada"
                                                                                                                                                                                   }
                                                                                                                                                                               ]
                                                                                                                                                            }
                                                                                                                                                        ]
                                                                                                                                  }
                                                                                                                              ]
