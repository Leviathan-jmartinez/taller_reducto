                                                                                                                                                                "name":  "Recibir transferencia",
                                                                                                                                                                "defaultDiagram":  true,
                                                                                                                                                                "ownedViews":  [
                                                                                                                                                                                   {
                                                                                                                                                                                       "_type":  "UMLNoteView",
                                                                                                                                                                                       "_id":  "ID000000000691",
                                                                                                                                                                                       "_parent":  {
