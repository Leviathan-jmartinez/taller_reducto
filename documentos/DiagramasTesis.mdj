                                                                                                                                                                            },
                                                                                                                                                                "name":  "Transferir stock",
                                                                                                                                                                "defaultDiagram":  true,
                                                                                                                                                                "ownedViews":  [
                                                                                                                                                                                   {
                                                                                                                                                                                       "_type":  "UMLNoteView",
                                                                                                                                                                                       "_id":  "ID000000000666",
                                                                                                                                                                                       "_parent":  {
                                                                                                                                                                                                       "$ref":  "ID000000000665"
                                                                                                                                                                                                   },
                                                                                                                                                                                       "font":  "Arial;13;0",
                                                                                                                                                                                       "parentStyle":  false,
                                                                                                                                                                                       "left":  50,
                                                                                                                                                                                       "top":  50,
                                                                                                                                                                                       "width":  900,
                                                                                                                                                                                       "height":  620,
                                                                                                                                                                                       "text":  "Convencion: Actor -\u003e Vista -\u003e Conexion -\u003e Entidades/Tablas\n\nParticipantes:\n- Actor\n- Vista\n- Conexion\n- sucursales\n- articulos\n- stock\n- transferencia_stock\n- transferencia_stock_detalle\n- movimientostock\n- nota_remision\n- nota_remision_detalle\n\nMensajes:\n1. Actor -\u003e Vista: selecciona sucursal destino\n2. Vista -\u003e Conexion: consulta sucursales activas\n3. Conexion -\u003e sucursales: retorna sucursales\n4. Actor -\u003e Vista: busca productos\n5. Vista -\u003e Conexion: consulta productos con stock\n6. Conexion -\u003e stock: consulta stock disponible\n7. Conexion -\u003e articulos: consulta articulos\n8. Conexion -\u003e Vista: retorna productos\n9. Actor -\u003e Vista: ingresa cantidades\n10. Vista -\u003e Vista: valida cantidad y stock\n11. Actor -\u003e Vista: confirma transferencia\n12. Vista -\u003e Conexion: llama conexion\n13. Conexion -\u003e transferencia_stock: inserta cabecera en transito\n14. Conexion -\u003e transferencia_stock_detalle: inserta detalle\n15. Conexion -\u003e stock: descuenta origen\n16. Conexion -\u003e movimientostock: registra salida\n17. Conexion -\u003e nota_remision: genera remision\n18. Conexion -\u003e nota_remision_detalle: inserta detalle remision\n19. Conexion -\u003e Vista: retorna transferencia generada"
                                                                                                                                                                                   }
                                                                                                                                                                               ]
                                                                                                                                                            }
                                                                                                                                                        ]
                                                                                                                                  }
                                                                                                                              ]
