                                                                                                                                                                                       "width":  900,
                                                                                                                                                                                       "height":  620,
                                                                                                                                                                                       "text":  "Convencion: Actor -\u003e Vista -\u003e Conexion -\u003e Entidades/Tablas\n\nParticipantes:\n- Actor\n- Vista\n- Conexion\n- recepcion_servicio\n- diagnostico_servicio\n- diagnostico_detalle\n\nMensajes:\n1. Actor -\u003e Vista: busca recepcion pendiente\n2. Vista -\u003e Conexion: consulta recepciones\n3. Conexion -\u003e recepcion_servicio: retorna recepciones\n4. Actor -\u003e Vista: carga diagnostico\n5. Vista -\u003e Vista: valida detalle\n6. Vista -\u003e Conexion: llama conexion\n7. Conexion -\u003e diagnostico_servicio: inserta diagnostico\n8. Conexion -\u003e diagnostico_detalle: inserta detalle\n9. Conexion -\u003e recepcion_servicio: actualiza estado\n10. Conexion -\u003e Vista: retorna diagnostico registrado"
                                                                                                                                                                                   }
                                                                                                                                                                               ]
                                                                                                                                                            }
                                                                                                                                                        ]
                                                                                                                                  }
