                                                                                                                                                                                       "top":  50,
                                                                                                                                                                                       "width":  900,
                                                                                                                                                                                       "height":  620,
                                                                                                                                                                                       "text":  "Convencion: Actor -\u003e Vista -\u003e Conexion -\u003e Entidades/Tablas\n\nParticipantes:\n- Actor\n- Vista\n- Conexion\n- orden_trabajo\n- orden_trabajo_detalle\n- registro_servicio\n- registro_servicio_detalle\n- stock\n- movimientostock\n\nMensajes:\n1. Actor -\u003e Vista: selecciona orden de trabajo\n2. Vista -\u003e Conexion: consulta orden\n3. Conexion -\u003e orden_trabajo: retorna orden\n4. Conexion -\u003e orden_trabajo_detalle: retorna detalle\n5. Actor -\u003e Vista: carga trabajo realizado\n6. Vista -\u003e Vista: valida detalle y stock\n7. Vista -\u003e Conexion: llama conexion\n8. Conexion -\u003e registro_servicio: inserta registro\n9. Conexion -\u003e registro_servicio_detalle: inserta detalle\n10. Conexion -\u003e stock: descuenta repuestos\n11. Conexion -\u003e movimientostock: registra consumo\n12. Conexion -\u003e orden_trabajo: actualiza estado\n13. Conexion -\u003e Vista: retorna servicio registrado"
                                                                                                                                                                                   }
                                                                                                                                                                               ]
                                                                                                                                                            }
                                                                                                                                                        ]
                                                                                                                                  }
                                                                                                                              ]
